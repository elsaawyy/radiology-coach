# ─── Radiology Coach — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in real values. Never commit .env to git.

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://radcoach:strongpassword@localhost:5432/radiology_coach

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-256bit-string

# CORS allowed origins (comma-separated for multiple)
# In dev: http://localhost:3000  |  In prod: https://your-app.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Environment flag
APP_ENV=development
